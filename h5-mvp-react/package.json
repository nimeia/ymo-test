{
  "name": "h5-mvp-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:seo": "node ./scripts/generate-fold-diagrams.mjs && node ./scripts/build-seo-assets.mjs",
